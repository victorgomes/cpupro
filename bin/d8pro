#!/usr/bin/env node
/* eslint-env node */

const {spawnSync} = require('child_process');
const path = require('path');
const os = require('os');
const fs = require('fs');
const readline = require('readline');

// Find d8 executable
const arch = os.arch() === 'arm64' ? 'arm64' : 'x64';
const d8Path = process.env.D8_PATH ||
               path.join(os.homedir(), `v8/v8/out/${arch}.release/d8`);

if (!fs.existsSync(d8Path)) {
  console.error(`Error: d8 not found at ${d8Path}`);
  console.error(
      `Please set D8_PATH or ensure d8 is at ~/v8/v8/out/${arch}.release/d8`);
  process.exit(1);
}

// 1. Clean up old Turbofan traces to avoid stale graphs
const currentDirFiles = fs.readdirSync(process.cwd());
for (const file of currentDirFiles) {
  if (file === 'turbo.cfg' || /^turbo-.*\.json$/.test(file)) {
    try {
      fs.unlinkSync(path.join(process.cwd(), file));
    } catch (e) {
      console.warn(`Could not remove old trace file ${file}:`, e);
    }
  }
}

// 2. Run d8 with --prof
const rawArgs = process.argv.slice(2);
const runTickProcessor = rawArgs.includes('--preprocess');
const args = rawArgs.filter(arg => arg !== '--preprocess');
const d8Args = [ '--prof', ...args ];

console.log(`Running: ${d8Path} ${d8Args.join(' ')}`);
const d8Result = spawnSync(d8Path, d8Args, {stdio : 'inherit'});

if (d8Result.error || d8Result.status !== 0) {
  console.error('d8 execution failed.');
  process.exit(d8Result.status || 1);
}

// Check for v8.log
const logPath = path.resolve('v8.log');
if (!fs.existsSync(logPath)) {
  console.error(`Error: Expected profile log not found at ${logPath}`);
  process.exit(1);
}

let cpuproTarget = logPath;

if (runTickProcessor) {
  // 2. Run tick processor
  const platform = os.platform();
  const processorName =
      platform === 'darwin' ? 'mac-tick-processor' : 'linux-tick-processor';
  const processorPath = path.join(os.homedir(), `v8/v8/tools/${processorName}`);

  if (!fs.existsSync(processorPath)) {
    console.error(`Error: Tick processor not found at ${processorPath}`);
    process.exit(1);
  }

  const jsonPath = path.resolve('v8.json');
  console.log(`Processing log with ${processorPath} > ${jsonPath}`);

  // We need to write the stdout to v8.json
  const processorArgs = [ 'v8.log', '--preprocess' ];
  const processorResult =
      spawnSync(processorPath, processorArgs,
                {stdio : [ 'inherit', fs.openSync(jsonPath, 'w'), 'inherit' ]});

  if (processorResult.error || processorResult.status !== 0) {
    console.error('Tick processor failed.');
    process.exit(processorResult.status || 1);
  }

  cpuproTarget = jsonPath;
}

// 4. Run cpupro on the generated trace
const cpuproPath = path.join(__dirname, 'cpupro');
const cpuproArgs = [ cpuproPath, cpuproTarget ];

if (fs.existsSync(path.resolve('turbo.cfg'))) {
  cpuproArgs.push('--turbofan', 'turbo.cfg');
}

console.log(`Analyzing with cpupro: node ${cpuproArgs.join(' ')}`);
const cpuproResult = spawnSync('node', cpuproArgs, {stdio : 'inherit'});

if (cpuproResult.error || cpuproResult.status !== 0) {
  console.error('cpupro execution failed.');
  process.exit(cpuproResult.status || 1);
}
